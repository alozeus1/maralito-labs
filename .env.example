# =============================================================================
# BorderPass / Maralito — Environment Variable Template (NAMES ONLY)
# NEVER put real secrets in this file. Copy to .env.local and fill via secret manager.
# Conventions: MARALITO_* (shared platform) · BORDERPASS_* (app-specific) · <PROVIDER>_*
# =============================================================================

# ---- Core ----
NODE_ENV=
APP_ENV=                                 # local | preview | staging | production
BORDERPASS_PUBLIC_APP_URL=
BORDERPASS_DEFAULT_LOCALE=               # en | es

# ---- Maralito Platform (shared, via @maralito/sdk) ----
MARALITO_SDK_BASE_URL=
MARALITO_SERVICE_TOKEN=                  # server-only
MARALITO_APP_ID=borderpass
MARALITO_KMS_KEY_ID=
MARALITO_KMS_PROVIDER=                   # supabase | aws | gcp

# ---- Supabase (Postgres + Auth + Storage) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=               # server-only — NEVER client
SUPABASE_JWT_SECRET=                     # server-only
SUPABASE_DB_URL=                         # pooled (DATABASE_URL)
SUPABASE_DB_DIRECT_URL=                  # direct (migrations)
SUPABASE_STORAGE_BUCKET=

# ---- Upstash Redis (cache / idempotency) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Stripe (Phase 4 — development/TEST mode only; never commit live keys) ----
STRIPE_SECRET_KEY=                       # server-only (sk_test_...)
STRIPE_WEBHOOK_SECRET=                   # server-only (whsec_...)
STRIPE_PUBLISHABLE_KEY=                  # public (pk_test_...) — not wired in Phase 4
STRIPE_API_VERSION=                      # optional; pinned default in code (verify before live)
STRIPE_PAYMENT_CURRENCY=usd              # optional; lowercase ISO-4217 (usd|mxn)
STRIPE_SUCCESS_URL=                      # optional (Checkout only; unused in Phase 4 PaymentIntent)
STRIPE_CANCEL_URL=                       # optional (Checkout only; unused in Phase 4 PaymentIntent)

# ---- Resend (email) ----
RESEND_API_KEY=                          # server-only
RESEND_FROM_EMAIL=
DEV_SYNTHETIC_NOTIFY_EMAIL=              # dev-only: synthetic recipient for POST /api/dev/dispatch-notifications

# ---- Twilio / WhatsApp (SMS/WA) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=                       # server-only
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
TWILIO_WEBHOOK_SECRET=                   # server-only

# ---- LangGraph / AI (model calls go through the AI gateway — NO provider keys in app) ----
LANGGRAPH_GATEWAY_URL=
LANGGRAPH_GATEWAY_KEY=                    # server-only
LANGGRAPH_CHECKPOINT_DB_URL=             # spike/Phase 2: Postgres for checkpointer
LANGSMITH_API_KEY=                       # optional eval/trace

# ---- Inngest (durable workflows) ----
INNGEST_EVENT_KEY=                       # server-only
INNGEST_SIGNING_KEY=                     # server-only

# ---- Sentry (errors/traces) ----
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                       # build-time only

# ---- PostHog (analytics) ----
POSTHOG_KEY=
POSTHOG_HOST=

# ---- Misc ----
CRON_SECRET=                             # server-only

# =============================================================================
# Phase 1 additions (auth/db foundation). Names only — no secrets.
# =============================================================================
# Supabase public config (browser-safe; used by browser + server clients)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Stripe publishable key (browser-safe, PUBLIC by design; Phase 5 Elements). Use pk_test_... in dev.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=      # public (pk_test_...) — NEVER the secret key
# Postgres connection for Drizzle (server-only)
DATABASE_URL=
# BorderPass app config
BORDERPASS_APP_URL=
BORDERPASS_ENV=                          # local | preview | staging | production
MARALITO_PLATFORM_ENV=                   # shared platform env name
# Dev-only super admin bootstrap for seed (local only)
SUPER_ADMIN_AUTH_USER_ID=                # optional, local seed only
DEV_ORG_ID=                              # optional, local seed only

# Phase 1.6: single shared customer org for new-user provisioning (ADR-0007)
BORDERPASS_DEFAULT_CUSTOMER_ORG_ID=
