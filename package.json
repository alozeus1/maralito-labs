{
  "name": "maralito",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "pnpm audit --audit-level=high",
    "check:db-imports": "node scripts/check-db-imports.mjs",
    "check:client-stripe": "node scripts/check-client-stripe-boundary.mjs",
    "preflight": "node scripts/preflight.mjs",
    "gate:rls": "pnpm --filter @maralito/db gate:rls"
  },
  "devDependencies": {
    "prettier-plugin-tailwindcss": "0.6.14",
    "turbo": "2.9.14",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
